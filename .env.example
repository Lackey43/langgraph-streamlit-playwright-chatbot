# LLM Configuration (OpenAI compatible endpoint - supports OpenAI, xAI Grok, Groq via OpenAI shim, etc.)
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini
# Optional base URL for non-OpenAI providers e.g. https://api.x.ai/v1 for Grok or https://api.groq.com/openai/v1
LLM_BASE_URL=
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=8192

# Persistence
DB_PATH=data/memory.db
MAX_MEMORY_STATES=6

# Playwright Settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000

# App Config
APP_TITLE="🧠 LangGraph Playwright Agentic Chatbot"
DEFAULT_USER_ID=demo_user
ENABLE_VISION=true  # If LLM supports image inputs (gpt-4o, grok-2-vision etc.)
